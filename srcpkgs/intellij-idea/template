# Template file for 'intellij-idea'
pkgname=intellij-idea
version=2026.1.2
revision=1
archs="x86_64"
depends="virtual?java-environment giflib libXtst hicolor-icon-theme"
short_desc="Java integrated development environment by JetBrains"
maintainer="Piekay <github@piekay.de>"
license="custom:Commercial"
homepage="https://www.jetbrains.org/"
distfiles="https://download.jetbrains.com/idea/idea-${version}.tar.gz"
checksum=e820175d1a7d0ee2492e7b38f6b7f046a132bfe4b082086d9b035edb03c777b1
repository=nonfree
restricted=yes
nopie=yes
python_version=3
skiprdeps="/usr/lib/intellij-idea/plugins/Kotlin/bin/linux/LLDBFrontend"

do_install() {
	vmkdir usr/bin
	vmkdir usr/share/doc/intellij-idea
	vmkdir usr/lib/intellij-idea
	vmkdir usr/share/pixmaps
	vmkdir usr/share/icons/hicolor/scalable/apps

	vcopy bin usr/lib/intellij-idea
	vcopy lib usr/lib/intellij-idea
	vcopy plugins usr/lib/intellij-idea
	vcopy product-info.json usr/lib/intellij-idea
	vcopy build.txt usr/lib/intellij-idea
	vcopy jbr usr/lib/intellij-idea
	vcopy license usr/share/doc/intellij-idea
	rm ${DESTDIR}/usr/lib/intellij-idea/lib/async-profiler -rf
	ln -sf ../lib/intellij-idea/bin/idea ${DESTDIR}/usr/bin/idea
	ln -sf ../../lib/intellij-idea/bin/idea.png ${DESTDIR}/usr/share/pixmaps/idea.png
	ln -sf ../../lib/intellij-idea/bin/idea.svg ${DESTDIR}/usr/share/icons/hicolor/scalable/apps/idea.svg
	vinstall ${FILESDIR}/idea.desktop 644 usr/share/applications idea.desktop
}
post_install() {
	vlicense ${FILESDIR}/EULA
}
